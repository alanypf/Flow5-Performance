<?xml version="1.0"?>
<sdf version="1.9">
  <model name="waterdrop">
    <pose>0 0 0 0 0 0</pose>
    <static>0</static>

    <link name="base_link">
      <pose degrees="true">0 0 0 0 0 0</pose>
      <!-- \todo provide proper inertial : actual mass 4.0 kg -->
      <!-- Post-stall aero coefficients replaced with Viterna-Corrigan model -->
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>4.0</mass>
        <inertia>
          <ixx>0.049</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.082</iyy>
          <iyz>0</iyz>
          <izz>0.058</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh>
            <uri>model://waterdrop/meshes/base_link.STL</uri>
          </mesh>
        </geometry>
      </collision>
      <visual name="fuselage_visual">
        <geometry>
          <mesh>
            <uri>model://waterdrop/meshes/base_link.STL</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.4 0.4 0.4</ambient>
          <diffuse>0.4 0.4 0.4</diffuse>
          <specular>0.3 0.3 0.3 1</specular>
        </material>
      </visual>

      <visual name="cp_aero">
        <pose>0.340 0 0 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.02</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>1 0.5 0</ambient>
          <diffuse>1 0.5 0</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>

      <collision name="leg1_collision">
        <pose>-0.26 -0.25 -0.16 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
      </collision>
      <collision name="leg2_collision">
        <pose>-0.26 0.25 0.16 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
      </collision>
      <collision name="leg3_collision">
        <pose>-0.26 0.25 -0.16 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
      </collision>
      <collision name="leg4_collision">
        <pose>-0.26 -0.25 0.16 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.01</radius>
          </sphere>
        </geometry>
      </collision>
    </link>

    <!-- CCW -->
    <joint name='motor1_joint' type='revolute'>
      <pose relative_to="base_link" degrees="true">0.042836 -0.22635 -0.11141 0 90 0</pose>
      <child>motor1_link</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>1e-5</damping>
        </dynamics>
      </axis>
    </joint>
    <link name="motor1_link">
      <pose relative_to="motor1_joint">0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.025</mass>
        <inertia>
          <ixx>0.000130417</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000130417</iyy>
          <iyz>0</iyz>
          <izz>0.000260417</izz>
        </inertia>
      </inertial>
      <collision name='link_1_collision'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://waterdrop/meshes/ccw_rotor.STL</uri>
          </mesh>
        </geometry>
      </collision>
      <visual name='link_1_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://waterdrop/meshes/ccw_rotor.STL</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.3</ambient>
          <diffuse>0.2 0.2 0.3</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <!-- CCW -->
    <joint name='motor2_joint' type='revolute'>
      <pose relative_to="base_link" degrees="true">0.042836 0.22635 0.11141 0 90 0</pose>
      <child>motor2_link</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>1e-5</damping>
        </dynamics>
      </axis>
    </joint>
    <link name="motor2_link">
      <pose relative_to="motor2_joint">0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.025</mass>
        <inertia>
          <ixx>0.000130417</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000130417</iyy>
          <iyz>0</iyz>
          <izz>0.000260417</izz>
        </inertia>
      </inertial>
      <collision name='link_2_collision'>
        <pose degrees="true">0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://waterdrop/meshes/ccw_rotor.STL</uri>
          </mesh>
        </geometry>
      </collision>
      <visual name='link_2_visual'>
        <pose degrees="true">0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://waterdrop/meshes/ccw_rotor.STL</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.2 0.4 0.2</ambient>
          <diffuse>0.2 0.4 0.2</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <!-- CW -->
    <joint name='motor3_joint' type='revolute'>
      <pose relative_to="base_link" degrees="true">0.042836 0.22635 -0.11141 0 90 0</pose>
      <child>motor3_link</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>1e-5</damping>
        </dynamics>
      </axis>
    </joint>
    <link name="motor3_link">
      <pose relative_to="motor3_joint">0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.025</mass>
        <inertia>
          <ixx>0.000130417</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000130417</iyy>
          <iyz>0</iyz>
          <izz>0.000260417</izz>
        </inertia>
      </inertial>
      <collision name='link_3_collision'>
        <pose degrees="true">0 0 0 0 180 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://waterdrop/meshes/cw_rotor.STL</uri>
          </mesh>
        </geometry>
      </collision>
      <visual name='link_3_visual'>
        <pose degrees="true">0 0 0 0 180 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://waterdrop/meshes/cw_rotor.STL</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.3</ambient>
          <diffuse>0.2 0.2 0.3</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <!-- CW -->
    <joint name='motor4_joint' type='revolute'>
      <pose relative_to="base_link" degrees="true">0.042836 -0.22635 0.11141 0 90 0</pose>
      <child>motor4_link</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <damping>1e-5</damping>
        </dynamics>
      </axis>
    </joint>
    <link name="motor4_link">
      <pose relative_to="motor4_joint">0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.025</mass>
        <inertia>
          <ixx>0.000130417</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.000130417</iyy>
          <iyz>0</iyz>
          <izz>0.000260417</izz>
        </inertia>
      </inertial>
      <collision name='link_4_collision'>
        <pose degrees="true">0 0 0 0 180 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://waterdrop/meshes/cw_rotor.STL</uri>
          </mesh>
        </geometry>
      </collision>
      <visual name='link_4_visual'>
        <pose degrees="true">0 0 0 0 180 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://waterdrop/meshes/cw_rotor.STL</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.2 0.4 0.2</ambient>
          <diffuse>0.2 0.4 0.2</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <!-- sensors -->
    <link name='imu_link'>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.00002</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00002</iyy>
          <iyz>0</iyz>
          <izz>0.00002</izz>
        </inertia>
      </inertial>
      <sensor name="imu_sensor" type="imu">
        <pose degrees="true">0 0 0 180 0 0</pose>
        <always_on>1</always_on>
        <update_rate>1000.0</update_rate>
      </sensor>
    </link>
    <joint name='imu_joint' type='fixed'>
      <child>imu_link</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <!-- plugins -->
    <plugin filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
    </plugin>
    <plugin filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>motor1_joint</joint_name>
    </plugin>
    <plugin filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>motor2_joint</joint_name>
    </plugin>
    <plugin filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>motor3_joint</joint_name>
    </plugin>
    <plugin filename="gz-sim-apply-joint-force-system"
      name="gz::sim::systems::ApplyJointForce">
      <joint_name>motor4_joint</joint_name>
    </plugin>

    <!-- prop1 (ccw) data-driven performance -->
    <plugin filename="PropellerPerformancePlugin"
        name="PropellerPerformancePlugin">
      <link_name>motor1_link</link_name>
      <joint_name>motor1_joint</joint_name>
      <performance_file>model://waterdrop/propellers/PER3_7x11E.csv</performance_file>
      <cw>false</cw>
    </plugin>

    <!-- prop2 (ccw) data-driven performance -->
    <plugin filename="PropellerPerformancePlugin"
        name="PropellerPerformancePlugin">
      <link_name>motor2_link</link_name>
      <joint_name>motor2_joint</joint_name>
      <performance_file>model://waterdrop/propellers/PER3_7x11E.csv</performance_file>
      <cw>false</cw>
    </plugin>

    <!-- prop3 (cw) data-driven performance -->
    <plugin filename="PropellerPerformancePlugin"
        name="PropellerPerformancePlugin">
      <link_name>motor3_link</link_name>
      <joint_name>motor3_joint</joint_name>
      <performance_file>model://waterdrop/propellers/PER3_7x11E.csv</performance_file>
      <cw>true</cw>
    </plugin>

    <!-- prop4 (cw) data-driven performance -->
    <plugin filename="PropellerPerformancePlugin"
        name="PropellerPerformancePlugin">
      <link_name>motor4_link</link_name>
      <joint_name>motor4_joint</joint_name>
      <performance_file>model://waterdrop/propellers/PER3_7x11E.csv</performance_file>
      <cw>true</cw>
    </plugin>

    <!-- whole-airframe aerodynamics: Viterna-Corrigan post-stall model
         Linear regime (α<12°): XFLR5 VLM derivatives (unchanged)
         Post-stall (α>12°→90°): Viterna method with CD_90=1.20 (flat plate)
         Replaces the original AdvancedLiftDrag extrapolation which diverged
         catastrophically at high AoA during tailsitter transition -->
    <plugin filename="gz-sim-advanced-lift-drag-system"
            name="gz::sim::systems::AdvancedLiftDrag">
      <air_density>1.2250</air_density>
      <area>0.062000</area>
      <AR>3.3098</AR>
      <mac>0.0675</mac>

      <a0> 0.001840</a0>
      <CL0>-0.007595</CL0>
      <CD0> 0.025286</CD0>
      <Cem0>-0.003779</Cem0>
      <CLa> 4.126931</CLa>
      <CDa> 0.000000</CDa>
      <Cema>-0.297268</Cema>
      <eff>1.0000</eff>

      <alpha_stall> 0.209440</alpha_stall>
      <CLa_stall>-0.629333</CLa_stall>
      <CDa_stall> 0.811045</CDa_stall>
      <Cema_stall> 0.048509</Cema_stall>

      <CYb>-0.964428</CYb>
      <CYp> 0.000000</CYp>
      <CYr> 0.363501</CYr>
      <CY0>0.000000</CY0>

      <Cl0>0.000000</Cl0>
      <Clb> 0.001880</Clb>
      <Clp>-0.649620</Clp>
      <Clr> 0.161455</Clr>

      <Cn0>0.000000</Cn0>
      <Cnb> 0.002110</Cnb>
      <Cnp>-0.080727</Cnp>
      <Cnr>-0.142030</Cnr>

      <!-- CP at AC position relative to CG (AC=340mm, CG=333mm from nose → 7mm aft) -->
      <cp>-0.007 0 0</cp>
      <forward>1 0 0</forward>
      <upward>0 0 1</upward>
      <link_name>base_link</link_name>
    </plugin>

    <plugin name="ArduPilotPlugin" filename="ArduPilotPlugin">
      <fdm_addr>127.0.0.1</fdm_addr>
      <fdm_port_in>9002</fdm_port_in>
      <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
      <lock_step>1</lock_step>
      <modelXYZToAirplaneXForwardZDown degrees="true">0 0 0 180 0 0</modelXYZToAirplaneXForwardZDown>
      <gazeboXYZToNED degrees="true">0 0 0 180 0 90</gazeboXYZToNED>
      <imuName>imu_sensor</imuName>
      <!--
          SERVO1_FUNCTION   33 (Motor1 Front Right CCW)
          SERVO1_MAX        2000
          SERVO1_MIN        1000
          SERVO1_REVERSED   0
          SERVO1_TRIM       1500
       -->
      <control channel="0">
        <jointName>motor1_joint</jointName>
        <useForce>1</useForce>
        <multiplier>2100</multiplier>
        <offset>0</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>0.05</p_gain>
        <i_gain>0.02</i_gain>
        <d_gain>0</d_gain>
        <i_max>2.5</i_max>
        <i_min>-2.5</i_min>
        <cmd_max>2.5</cmd_max>
        <cmd_min>-2.5</cmd_min>
      </control>

      <!--
          SERVO2_FUNCTION   34 (Motor2 Back Left CCW)
          SERVO2_MAX        2000
          SERVO2_MIN        1000
          SERVO2_REVERSED   0
          SERVO2_TRIM       1500
       -->
      <control channel="1">
        <jointName>motor2_joint</jointName>
        <useForce>1</useForce>
        <multiplier>2100</multiplier>
        <offset>0</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>0.05</p_gain>
        <i_gain>0.02</i_gain>
        <d_gain>0</d_gain>
        <i_max>2.5</i_max>
        <i_min>-2.5</i_min>
        <cmd_max>2.5</cmd_max>
        <cmd_min>-2.5</cmd_min>
      </control>

      <!--
          SERVO3_FUNCTION   35 (Motor3 Front Left CW)
          SERVO3_MAX        2000
          SERVO3_MIN        1000
          SERVO3_REVERSED   0
          SERVO3_TRIM       1500
       -->
      <control channel="2">
        <jointName>motor3_joint</jointName>
        <useForce>1</useForce>
        <multiplier>-2100</multiplier>
        <offset>0</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>0.05</p_gain>
        <i_gain>0.02</i_gain>
        <d_gain>0</d_gain>
        <i_max>2.5</i_max>
        <i_min>-2.5</i_min>
        <cmd_max>2.5</cmd_max>
        <cmd_min>-2.5</cmd_min>
      </control>

      <!--
          SERVO4_FUNCTION   36 (Motor4 Back Right CW)
          SERVO4_MAX        2000
          SERVO4_MIN        1000
          SERVO4_REVERSED   0
          SERVO4_TRIM       1500
       -->
      <control channel="3">
        <jointName>motor4_joint</jointName>
        <useForce>1</useForce>
        <multiplier>-2100</multiplier>
        <offset>0</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>0.05</p_gain>
        <i_gain>0.02</i_gain>
        <d_gain>0</d_gain>
        <i_max>2.5</i_max>
        <i_min>-2.5</i_min>
        <cmd_max>2.5</cmd_max>
        <cmd_min>-2.5</cmd_min>
      </control>
    </plugin>
  </model>
</sdf>
