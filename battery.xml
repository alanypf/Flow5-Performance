<?xml version="1.0" encoding="UTF-8"?>
<battery>
    <name>Tattu 12S 6200mAh 85C</name>
    <chemistry>LiPo</chemistry>

    <!-- Pack configuration: S cells in series, P strings in parallel -->
    <configuration>
        <series>12</series>
        <parallel>1</parallel>
    </configuration>

    <!-- Per-cell properties -->
    <cell>
        <V_nominal unit="V">3.7</V_nominal>
        <V_full    unit="V">4.2</V_full>
        <V_empty   unit="V">3.3</V_empty>
        <capacity  unit="Ah">6.2</capacity>
        <R_internal unit="ohm">0.005</R_internal>
    </cell>

    <!-- Optional pack-level limits -->
    <C_rating unit="1/h">85</C_rating>
</battery>
